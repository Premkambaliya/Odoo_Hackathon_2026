generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  SCHEDULED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseType {
  FUEL
  MAINTENANCE
  TOLL
  PARKING
  REPAIR
  OTHER
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          Role     @default(DRIVER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  driverProfile Driver?
}

model Vehicle {
  id                  String          @id @default(uuid())
  registration_number String          @unique
  name_model          String
  manufacturer        String
  type                String
  fuel_type           String          // Petrol, Diesel, CNG, Electric
  acquisition_date    DateTime?
  acquisition_cost    Float
  odometer            Float           @default(0)
  max_load_capacity   Float
  status              VehicleStatus   @default(AVAILABLE)
  
  // Documents (Mandatory RC, Insurance, PUC)
  rc_number            String
  rc_file_path         String
  
  insurance_company    String?
  insurance_policy_num String?
  insurance_type       String?         // Third Party, Comprehensive, Own Damage
  insurance_start_date DateTime?
  insurance_expiry_date DateTime?
  insurance_file_path  String
  
  puc_number           String?
  puc_expiry_date      DateTime?
  puc_file_path        String
  
  permit_number        String?
  permit_expiry_date   DateTime?
  permit_file_path     String?
  
  // Additional Notes
  description          String?
  internal_remarks     String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  trips               Trip[]
  maintenanceLogs     MaintenanceLog[]
  fuelLogs            FuelLog[]
  expenses            Expense[]
  odometerLogs        OdometerLog[]
}

model Driver {
  id                  String        @id @default(uuid())
  user_id             String        @unique
  user                User          @relation(fields: [user_id], references: [id])
  name                String
  license_number      String        @unique
  license_category    String
  license_expiry_date DateTime
  contact_number      String
  safety_score        Float         @default(100)
  status              DriverStatus  @default(AVAILABLE)

  // Section 1: Personal Info
  profile_photo_path    String?
  address               String?
  emergency_contact_name String?
  emergency_contact_phone String?
  joining_date          DateTime?
  monthly_salary        Float?       @default(0)

  // Section 2: Driving License
  license_issue_date    DateTime?
  license_file_path     String?      // DL upload path

  // Section 3: Identity Documents
  aadhaar_number        String?
  aadhaar_file_path     String?      // Aadhaar PDF/Image upload path
  pan_file_path         String?      // PAN PDF upload path
  medical_cert_path     String?      // Medical Fitness Certificate upload path
  police_verification_path String?   // Police Verification Certificate upload path

  // Section 4: Employment Details
  internal_notes        String?
  admin_remarks         String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  trips               Trip[]
  payrollRecords      Payroll[]
  violations          Violation[]
}

model Payroll {
  id               String       @id @default(uuid())
  driver_id        String
  driver           Driver       @relation(fields: [driver_id], references: [id], onDelete: Cascade)
  month            String       // e.g. "July 2026"
  base_salary      Float
  bonus            Float        @default(0)
  deductions       Float        @default(0)
  final_salary     Float
  payment_status   String       @default("PENDING") // "PAID", "PENDING"
  payment_date     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Violation {
  id               String       @id @default(uuid())
  driver_id        String
  driver           Driver       @relation(fields: [driver_id], references: [id], onDelete: Cascade)
  description      String
  points_deducted  Float        @default(5)
  date             DateTime     @default(now())
}

model Trip {
  id               String     @id @default(uuid())
  source           String
  destination      String
  cargo_weight     Float
  planned_distance Float
  status           TripStatus @default(DRAFT)
  
  start_time       DateTime?
  end_time         DateTime?
  start_odometer   Float?
  final_odometer   Float?
  actual_distance  Float?
  fuel_consumed    Float?
  fuel_cost        Float?
  
  trip_type        String     @default("DELIVERY") // DELIVERY, INTERNAL
  reason           String?    // e.g. "Parking Movement", "Service Visit", etc.
  final_proof_path String?
  remarks          String?

  // Additional specifications from tripmodule.md
  priority         String     @default("MEDIUM") // LOW, MEDIUM, HIGH, EMERGENCY
  expected_delivery DateTime?
  special_instructions String?

  // Pickup Customer Details
  pickup_customer_name  String?
  pickup_company_name   String?
  pickup_gst_number     String?
  pickup_contact_person String?
  pickup_mobile         String?
  pickup_alt_mobile     String?
  pickup_email          String?
  pickup_street         String?
  pickup_area           String?
  pickup_city           String?
  pickup_state          String?
  pickup_country        String?
  pickup_pincode        String?
  pickup_maps_link      String?

  // Delivery Customer Details
  delivery_customer_name  String?
  delivery_company_name   String?
  delivery_gst_number     String?
  delivery_contact_person String?
  delivery_mobile         String?
  delivery_alt_mobile     String?
  delivery_email          String?
  delivery_street         String?
  delivery_area           String?
  delivery_city           String?
  delivery_state          String?
  delivery_country        String?
  delivery_pincode        String?
  delivery_maps_link      String?

  // Goods Info
  goods_name             String?
  goods_quantity         Float?
  goods_volume           Float?
  goods_package_count    Int?
  is_fragile             Boolean    @default(false)
  is_perishable          Boolean    @default(false)
  is_hazardous           Boolean    @default(false)
  special_handling_notes String?

  // Route Info
  loading_start_time     DateTime?
  loading_end_time       DateTime?
  departure_time         DateTime?
  estimated_duration     Float?
  stops_count            Int        @default(0)
  route_notes            String?

  // Financial details
  driver_allowance       Float      @default(0)
  loading_charges        Float      @default(0)
  unloading_charges      Float      @default(0)
  toll_estimate          Float      @default(0)
  misc_estimate          Float      @default(0)
  expected_revenue       Float      @default(0)

  // Attachments
  invoice_file_path          String?
  challan_file_path          String?
  eway_bill_file_path        String?
  purchase_order_file_path   String?
  other_doc_file_path        String?

  // Delivery completion
  receiver_name          String?
  receiver_mobile        String?
  customer_signature_path String?

  vehicle_id       String
  vehicle          Vehicle    @relation(fields: [vehicle_id], references: [id])
  driver_id        String
  driver           Driver     @relation(fields: [driver_id], references: [id])

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model OdometerLog {
  id               String     @id @default(uuid())
  vehicle_id       String
  vehicle          Vehicle    @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  odometer         Float
  reading_time     DateTime   @default(now())
  remarks          String?
}

model MaintenanceLog {
  id               String   @id @default(uuid())
  description      String
  cost             Float
  start_date       DateTime @default(now())
  end_date         DateTime?
  is_active        Boolean  @default(true) // Maps to In Shop status when true
  maintenance_type String?
  garage           String?
  odometer         Float?

  vehicle_id       String
  vehicle          Vehicle  @relation(fields: [vehicle_id], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FuelLog {
  id           String   @id @default(uuid())
  liters       Float
  cost         Float
  date         DateTime @default(now())
  fuel_station String?
  odometer     Float?

  vehicle_id   String
  vehicle      Vehicle  @relation(fields: [vehicle_id], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id           String      @id @default(uuid())
  expense_type ExpenseType
  amount       Float
  date         DateTime    @default(now())
  description  String?

  vehicle_id   String
  vehicle      Vehicle     @relation(fields: [vehicle_id], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
