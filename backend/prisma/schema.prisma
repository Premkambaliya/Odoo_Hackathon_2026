generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum ExpenseType {
  FUEL
  MAINTENANCE
  TOLL
  PARKING
  REPAIR
  OTHER
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          Role     @default(DRIVER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  driverProfile Driver?
}

model Vehicle {
  id                  String          @id @default(uuid())
  registration_number String          @unique
  name_model          String
  manufacturer        String
  type                String
  fuel_type           String          // Petrol, Diesel, CNG, Electric
  acquisition_date    DateTime?
  acquisition_cost    Float
  odometer            Float           @default(0)
  max_load_capacity   Float
  status              VehicleStatus   @default(AVAILABLE)
  
  // Documents (Mandatory RC, Insurance, PUC)
  rc_number            String
  rc_file_path         String
  
  insurance_company    String?
  insurance_policy_num String?
  insurance_type       String?         // Third Party, Comprehensive, Own Damage
  insurance_start_date DateTime?
  insurance_expiry_date DateTime?
  insurance_file_path  String
  
  puc_number           String?
  puc_expiry_date      DateTime?
  puc_file_path        String
  
  permit_number        String?
  permit_expiry_date   DateTime?
  permit_file_path     String?
  
  // Additional Notes
  description          String?
  internal_remarks     String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  trips               Trip[]
  maintenanceLogs     MaintenanceLog[]
  fuelLogs            FuelLog[]
  expenses            Expense[]
}

model Driver {
  id                  String        @id @default(uuid())
  user_id             String        @unique
  user                User          @relation(fields: [user_id], references: [id])
  name                String
  license_number      String        @unique
  license_category    String
  license_expiry_date DateTime
  contact_number      String
  safety_score        Float         @default(100)
  status              DriverStatus  @default(AVAILABLE)

  // Section 1: Personal Info
  profile_photo_path    String?
  address               String?
  emergency_contact_name String?
  emergency_contact_phone String?
  joining_date          DateTime?
  monthly_salary        Float?       @default(0)

  // Section 2: Driving License
  license_issue_date    DateTime?
  license_file_path     String?      // DL upload path

  // Section 3: Identity Documents
  aadhaar_number        String?
  aadhaar_file_path     String?      // Aadhaar PDF/Image upload path
  pan_file_path         String?      // PAN PDF upload path
  medical_cert_path     String?      // Medical Fitness Certificate upload path
  police_verification_path String?   // Police Verification Certificate upload path

  // Section 4: Employment Details
  internal_notes        String?
  admin_remarks         String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  trips               Trip[]
  payrollRecords      Payroll[]
  violations          Violation[]
}

model Payroll {
  id               String       @id @default(uuid())
  driver_id        String
  driver           Driver       @relation(fields: [driver_id], references: [id], onDelete: Cascade)
  month            String       // e.g. "July 2026"
  base_salary      Float
  bonus            Float        @default(0)
  deductions       Float        @default(0)
  final_salary     Float
  payment_status   String       @default("PENDING") // "PAID", "PENDING"
  payment_date     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Violation {
  id               String       @id @default(uuid())
  driver_id        String
  driver           Driver       @relation(fields: [driver_id], references: [id], onDelete: Cascade)
  description      String
  points_deducted  Float        @default(5)
  date             DateTime     @default(now())
}

model Trip {
  id               String     @id @default(uuid())
  source           String
  destination      String
  cargo_weight     Float
  planned_distance Float
  status           TripStatus @default(DRAFT)
  
  start_time       DateTime?
  end_time         DateTime?
  final_odometer   Float?
  actual_distance  Float?
  fuel_consumed    Float?
  fuel_cost        Float?

  vehicle_id       String
  vehicle          Vehicle    @relation(fields: [vehicle_id], references: [id])
  driver_id        String
  driver           Driver     @relation(fields: [driver_id], references: [id])

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model MaintenanceLog {
  id               String   @id @default(uuid())
  description      String
  cost             Float
  start_date       DateTime @default(now())
  end_date         DateTime?
  is_active        Boolean  @default(true) // Maps to In Shop status when true
  maintenance_type String?
  garage           String?
  odometer         Float?

  vehicle_id       String
  vehicle          Vehicle  @relation(fields: [vehicle_id], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FuelLog {
  id           String   @id @default(uuid())
  liters       Float
  cost         Float
  date         DateTime @default(now())
  fuel_station String?
  odometer     Float?

  vehicle_id   String
  vehicle      Vehicle  @relation(fields: [vehicle_id], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id           String      @id @default(uuid())
  expense_type ExpenseType
  amount       Float
  date         DateTime    @default(now())
  description  String?

  vehicle_id   String
  vehicle      Vehicle     @relation(fields: [vehicle_id], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
